SERVICE_NAME=rusty-todoish
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8080
SERVICE_VERSION=0.1.0

REDIS_NAME=rusty-todoish-redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}"

POSTGRES_DATABASE_NAME=rusty-todoish-postgres
POSTGRES_USERNAME=root
POSTGRES_PASSWORD=root
POSTGRES_PORT=5432
POSTGRES_ADDRESS=localhost
DATABASE_URL="postgres://${POSTGRES_USERNAME}:${POSTGRES_PASSWORD}@${POSTGRES_ADDRESS}:${POSTGRES_PORT}/${POSTGRES_DATABASE_NAME}"